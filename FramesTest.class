import org.openqa.selenium.By;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;
import org.testng.annotations.Test;
import java.time.Duration;
import static org.testng.Assert.*;

public class JavaScriptAlertsTest extends BaseTest {
    private WebDriverWait getWait() {
        return new WebDriverWait(driver, Duration.ofSeconds(5));
    }

    @Test
    public void testJSAlert() {
        driver.get(BASE_URL + "/javascript_alerts");
        driver.findElement(By.xpath("//button[text()='Click for JS Alert']")).click();
        getWait().until(ExpectedConditions.alertIsPresent()).accept();
        assertEquals(driver.findElement(By.id("result")).getText(), "You successfuly clicked an alert");
    }

    @Test
    public void testJSConfirmDismiss() {
        driver.get(BASE_URL + "/javascript_alerts");
        driver.findElement(By.xpath("//button[text()='Click for JS Confirm']")).click();
        getWait().until(ExpectedConditions.alertIsPresent()).dismiss();
        assertEquals(driver.findElement(By.id("result")).getText(), "You clicked: Cancel");
    }

    @Test
    public void testJSPrompt() {
        driver.get(BASE_URL + "/javascript_alerts");
        driver.findElement(By.xpath("//button[text()='Click for JS Prompt']")).click();
        var alert = getWait().until(ExpectedConditions.alertIsPresent());
        alert.sendKeys("TestInput");
        alert.accept();
        assertEquals(driver.findElement(By.id("result")).getText(), "You entered: TestInput");
    }
}