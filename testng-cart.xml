package pages;

import org.openqa.selenium.WebDriver;
import org.openqa.selenium.support.ui.ExpectedConditions;
import org.openqa.selenium.support.ui.WebDriverWait;
import java.time.Duration;

public class LoginPage {
    private final WebDriver driver;

    public LoginPage(WebDriver driver) { this.driver = driver; }

    public void open() {
        driver.get("https://www.sharelane.com/cgi-bin/log_in.py");
    }

    public void login(String email, String password) {
        String url = "https://www.sharelane.com/cgi-bin/log_in.py" +
                "?email=" + email +
                "&password=" + password;
        driver.get(url);
        new WebDriverWait(driver, Duration.ofSeconds(3))
                .until(ExpectedConditions.urlContains("log_in.py?email="));
    }

    public boolean isSuccess() {
        new WebDriverWait(driver, Duration.ofSeconds(3))
                .until(ExpectedConditions.urlContains("main.py"));
        return driver.getPageSource().contains("Logout");
    }

    public boolean hasError() {
        return driver.getPageSource().contains("Oops");
    }
}